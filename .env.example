# Flask Configuration
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# Database Configuration
# Format: postgresql://username:password@localhost:5432/zenture_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/zenture_wellness

# Email Configuration (SMTP/Gmail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_USE_TLS=false
MAIL_USE_SSL=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Maileroo Configuration (Alternative Email Service)
MAILEROO_API_KEY=your-maileroo-api-key

# Cloudinary Configuration (Media Uploads)
cloud_name=your-cloudinary-cloud-name
api_key=your-cloudinary-api-key
api_secret=your-cloudinary-api-secret

# Inference Server Configuration (if separate)
# INFERENCE_SERVER_URL=http://localhost:5001
